<?xml version="1.0" encoding="utf-8"?>
<resources>

  <!--<style name="NanoTimerTheme" parent="Theme.AppCompat.Light.DarkActionBar">-->
  <!--<style name="NanoTimerTheme" parent="Theme.AppCompat">-->
  <style name="NanoTimerTheme" parent="Theme.AppCompat">
    <item name="colorPrimary">@color/color_primary</item>
    <item name="colorPrimaryDark">@color/color_primary_dark</item>
    <item name="colorAccent">@color/color_accent</item>
    <item name="actionBarStyle">@style/NanoTimerActionBar</item>

    <!-- Catches dialogs the framework builds for us (preference dialogs), which take no theme argument. -->
    <item name="android:alertDialogTheme">@style/NanoTimerDialogTheme</item>

    <!--<item name="homeAsUpIndicator">@drawable/icon</item>-->
    <!--<item name="android:homeAsUpIndicator">@drawable/icon</item>-->

    <!--<item name="android:actionBarStyle">@style/NanoTimerActionBar</item>-->
    <!--<item name="actionBarStyle">@style/NanoTimerActionBar</item>-->
    <!--<item name="android:actionOverflowButtonStyle">@style/NanoTimerActionButtonOverflow</item>-->
    <!--<item name="actionOverflowButtonStyle">@style/NanoTimerActionButtonOverflow</item>-->
    <!--<item name="android:listViewStyle">@style/NanoTimerListView</item>-->
    <!--<item name="android:windowBackground">@color/graybg</item>-->
  </style>

  <style name="Toolbar.CustomTitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
    <item name="android:textSize">20sp</item>
    <item name="android:textStyle">bold</item>
    <item name="android:textColor">@color/white</item>
    <item name="android:letterSpacing">0.02</item>
  </style>

  <!-- Solid action bar with the consistent title appearance, used by the ActionBar screens. -->
  <style name="NanoTimerActionBar" parent="Widget.AppCompat.ActionBar.Solid">
    <item name="background">@color/color_primary</item>
    <item name="titleTextStyle">@style/Toolbar.CustomTitleText</item>
    <item name="elevation">4dp</item>
  </style>

  <style name="NanoTimerThemeNoActionBar" parent="Theme.AppCompat.NoActionBar">
    <item name="colorPrimary">@color/color_primary</item>
    <item name="colorPrimaryDark">@color/color_primary_dark</item>
    <item name="colorAccent">@color/color_accent</item>

    <item name="android:alertDialogTheme">@style/NanoTimerDialogTheme</item>
    <item name="android:listViewStyle">@style/NanoTimerListView</item>
  </style>

  <!--<style name="NanoTimerActionBar" parent="Widget.AppCompat.ActionBar">
    <item name="android:background">@drawable/actionbar_bg</item>
    <item name="background">@drawable/actionbar_bg</item>
  </style>-->

  <style name="NanoTimerActionButtonOverflow" parent="Widget.AppCompat.ActionButton.Overflow">
    <item name="android:minWidth">48dp</item>
    <item name="android:padding">0dp</item>
  </style>

  <style name="NanoTimerListView" parent="Widget.AppCompat.ListView.Menu">
    <item name="android:cacheColorHint">@color/transparent</item>
    <item name="android:divider">@color/gray800</item>
    <item name="android:dividerHeight">1dp</item>
  </style>

  <!-- Modern dark rounded frame for app dialogs (Add time, session details, …). -->
  <style name="NanoTimerDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
    <item name="android:windowBackground">@drawable/dialog_window_bg</item>
    <item name="colorAccent">@color/lightblue</item>
    <item name="android:textColorPrimary">@color/white</item>
    <item name="android:windowMinWidthMinor">92%</item>
    <item name="android:windowMinWidthMajor">70%</item>
    <item name="buttonBarButtonStyle">@style/NanoTimerDialogButton</item>
  </style>

  <!-- Bottom action buttons for the dialogs above: sentence-case, accent, comfortable tap target. -->
  <style name="NanoTimerDialogButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
    <item name="android:textColor">@color/lightblue</item>
    <item name="android:textStyle">bold</item>
    <item name="android:textSize">15sp</item>
    <item name="android:letterSpacing">0.02</item>
    <item name="android:minHeight">44dp</item>
  </style>

</resources>
