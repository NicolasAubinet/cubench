<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
   android:layout_width="match_parent"
   android:layout_height="wrap_content"
   android:minHeight="48dp"
   android:paddingLeft="@dimen/space_m"
   android:paddingRight="@dimen/space_m"
   android:paddingTop="@dimen/space_s"
   android:paddingBottom="@dimen/space_s">

  <!-- Muted timestamp (leading) -->
  <TextView
     android:id="@+id/tvDate"
     android:layout_width="wrap_content"
     android:layout_height="wrap_content"
     android:layout_alignParentLeft="true"
     android:layout_alignParentStart="true"
     android:layout_centerVertical="true"
     android:textColor="@color/secondary_text"
     android:textSize="15sp"
     android:singleLine="true"/>

  <!-- Strong solve result (trailing), tabular digits so the column aligns -->
  <TextView
     android:id="@+id/tvTime"
     android:layout_width="wrap_content"
     android:layout_height="wrap_content"
     android:layout_alignParentRight="true"
     android:layout_alignParentEnd="true"
     android:layout_centerVertical="true"
     android:textStyle="bold"
     android:textSize="17sp"
     android:fontFeatureSettings="tnum"
     android:singleLine="true"/>

  <!-- Status icon cluster, right-to-left: where the solve came from, PB trophy, comment -->

  <!-- One slot, one mark: the circle for a solve timed by hand, the cube for one the cube timed
       itself. Wrapped so the icons after it keep their anchor whichever of the two is showing,
       and sized by that mark so a manual solve's row is spaced exactly as it was. -->
  <FrameLayout
     android:id="@+id/solveSourceMarker"
     android:layout_width="wrap_content"
     android:layout_height="wrap_content"
     android:layout_centerVertical="true"
     android:layout_toLeftOf="@+id/tvTime"
     android:layout_toStartOf="@+id/tvTime"
     android:layout_marginRight="@dimen/space_s"
     android:layout_marginEnd="@dimen/space_s">
    <ImageView
       android:id="@+id/imgCircle"
       android:layout_width="7dp"
       android:layout_height="7dp"
       android:layout_gravity="center"
       android:src="@drawable/history_circle"/>
    <ImageView
       android:id="@+id/imgSmartCube"
       android:layout_width="14dp"
       android:layout_height="14dp"
       android:layout_gravity="center"
       android:visibility="gone"
       android:src="@drawable/ic_smartcube_solve"/>
  </FrameLayout>

  <ImageView
     android:id="@+id/imgPb"
     android:layout_width="16dp"
     android:layout_height="16dp"
     android:layout_centerVertical="true"
     android:layout_toLeftOf="@+id/solveSourceMarker"
     android:layout_toStartOf="@+id/solveSourceMarker"
     android:layout_marginRight="@dimen/space_s"
     android:layout_marginEnd="@dimen/space_s"
     android:src="@drawable/trophy"/>

  <ImageView
     android:id="@+id/imgComment"
     android:layout_width="16dp"
     android:layout_height="16dp"
     android:layout_centerVertical="true"
     android:layout_toLeftOf="@+id/imgPb"
     android:layout_toStartOf="@+id/imgPb"
     android:layout_marginRight="@dimen/space_s"
     android:layout_marginEnd="@dimen/space_s"
     android:src="@drawable/comment"/>

</RelativeLayout>
