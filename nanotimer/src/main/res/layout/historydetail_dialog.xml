<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
   xmlns:custom="http://schemas.android.com/apk/res-auto"
   android:orientation="vertical"
   android:layout_width="match_parent"
   android:layout_height="wrap_content"
   android:paddingLeft="16dp"
   android:paddingRight="16dp"
   android:paddingTop="8dp"
   android:paddingBottom="12dp"
   android:minWidth="300dp">

  <!-- The grip: what says the sheet can be dragged back down to close it. -->
  <View
     android:layout_width="32dp"
     android:layout_height="4dp"
     android:layout_gravity="center_horizontal"
     android:layout_marginBottom="10dp"
     android:background="@drawable/bottomsheet_drag_handle"/>

  <!-- Hero: solve time + PB trophy, flanked by the two actions on the solve itself -->
  <LinearLayout
     android:layout_width="match_parent"
     android:layout_height="wrap_content"
     android:orientation="horizontal"
     android:gravity="center_vertical">
    <ImageButton
       android:id="@+id/buComment"
       android:layout_width="44dp"
       android:layout_height="44dp"
       android:scaleType="fitCenter"
       android:padding="10dp"
       android:background="?android:attr/selectableItemBackgroundBorderless"
       android:src="@drawable/comment"
       android:contentDescription="@string/comment"/>
    <LinearLayout
       android:layout_width="0dp"
       android:layout_height="wrap_content"
       android:layout_weight="1"
       android:orientation="horizontal"
       android:gravity="center">
      <TextView
         android:id="@+id/tvTime"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"
         android:layout_gravity="center_vertical"
         android:textColor="@color/white"
         android:textStyle="bold"
         android:fontFeatureSettings="tnum"
         android:textSize="36sp"/>
      <ImageView
         android:id="@+id/imgPb"
         android:layout_width="28dp"
         android:layout_height="28dp"
         android:layout_gravity="center_vertical"
         android:layout_marginLeft="8dp"
         android:src="@drawable/trophy"/>
    </LinearLayout>
    <ImageButton
       android:id="@+id/buShareTime"
       android:layout_width="44dp"
       android:layout_height="44dp"
       android:scaleType="fitCenter"
       android:padding="8dp"
       android:background="?android:attr/selectableItemBackgroundBorderless"
       android:src="@android:drawable/ic_menu_share"
       android:contentDescription="@string/share_time"/>
  </LinearLayout>

  <!-- Date subtitle -->
  <TextView
     android:id="@+id/tvDate"
     android:layout_width="match_parent"
     android:layout_height="wrap_content"
     android:layout_marginTop="2dp"
     android:gravity="center"
     android:textColor="@color/secondary_text"
     android:textSize="14sp"/>

  <!-- The only child that may shrink: it gives up its height to the actions below rather than
       pushing them out of the window when the breakdown is long. Nested rather than plain, so the
       sheet lets it scroll back up instead of reading the drag as a pull on itself. -->
  <androidx.core.widget.NestedScrollView
     android:layout_width="match_parent"
     android:layout_height="wrap_content"
     android:layout_weight="1"
     android:layout_marginTop="2dp">

    <LinearLayout
       android:orientation="vertical"
       android:layout_width="match_parent"
       android:layout_height="wrap_content">

      <!-- Steps (multi-step solves) -->
      <LinearLayout
         android:id="@+id/trSteps"
         android:layout_width="match_parent"
         android:layout_height="wrap_content"
         android:orientation="horizontal"
         android:gravity="center"
         android:layout_marginBottom="4dp"
         android:visibility="gone">
        <TextView
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:text="@string/stepsC"
           android:textColor="@color/secondary_text"
           android:textSize="15sp"/>
        <TextView
           android:id="@+id/tvSteps"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:layout_marginLeft="8dp"
           android:textColor="@color/white"
           android:textStyle="bold"
           android:textSize="15sp"/>
      </LinearLayout>

      <!-- Mean of 3 (blind solves) -->
      <LinearLayout
         android:id="@+id/trMeanOfThree"
         android:layout_width="match_parent"
         android:layout_height="wrap_content"
         android:orientation="horizontal"
         android:gravity="center"
         android:layout_marginBottom="4dp"
         android:visibility="gone">
        <TextView
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:text="@string/mean_of_three"
           android:textColor="@color/secondary_text"
           android:textSize="15sp"/>
        <TextView
           android:id="@+id/tvMeanOfThree"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:layout_marginLeft="8dp"
           android:textColor="@color/white"
           android:textStyle="bold"
           android:textSize="15sp"/>
      </LinearLayout>

      <!-- Scramble header: label on the left, the scramble-derived tools on the right. Each tool
           button is shown only when it applies to this solve (see HistoryDetailDialog). -->
      <LinearLayout
         android:id="@+id/scrambleHeader"
         android:layout_width="match_parent"
         android:layout_height="wrap_content"
         android:orientation="horizontal"
         android:gravity="center_vertical"
         android:layout_marginBottom="4dp">
        <TextView
           android:text="@string/scramble"
           android:layout_gravity="center_vertical"
           style="@style/DialogSectionLabel"/>
        <Space
           android:layout_width="0dp"
           android:layout_height="wrap_content"
           android:layout_weight="1"/>
        <ImageButton
           android:id="@+id/buScrambleView"
           android:layout_width="32dp"
           android:layout_height="32dp"
           android:scaleType="fitCenter"
           android:padding="6dp"
           android:background="?android:attr/selectableItemBackgroundBorderless"
           android:src="@drawable/ic_scramble_view"
           android:contentDescription="@string/scramble_view"/>
        <ImageButton
           android:id="@+id/buCrossSolver"
           android:layout_width="32dp"
           android:layout_height="32dp"
           android:layout_marginLeft="4dp"
           android:scaleType="fitCenter"
           android:padding="6dp"
           android:background="?android:attr/selectableItemBackgroundBorderless"
           android:src="@drawable/ic_menu_cross_solver"
           android:contentDescription="@string/cross_solver"/>
      </LinearLayout>

      <!-- Scramble card (tap to copy) -->
      <androidx.cardview.widget.CardView
         android:id="@+id/scrambleCard"
         android:layout_width="match_parent"
         android:layout_height="wrap_content"
         android:clickable="true"
         android:focusable="true"
         android:foreground="?android:attr/selectableItemBackground"
         style="@style/TableCardView">
        <com.cube.nanotimer.util.view.FontFitTextView
           android:id="@+id/tvScramble"
           style="@style/ScrambleTextField"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:padding="12dp"
           android:textSize="15sp"
           custom:myfont="MONOSPACE"/>
      </androidx.cardview.widget.CardView>

      <!-- Solve breakdown (smart-cube solves only): the step bar, then the step times -->
      <LinearLayout
         android:id="@+id/breakdownSection"
         android:orientation="vertical"
         android:layout_width="match_parent"
         android:layout_height="wrap_content"
         android:layout_marginTop="14dp"
         android:visibility="gone">

        <!-- Label, the solve's move count and turn rate, then the switch that turns the table into
             a full reconstruction without moving anything already on screen. -->
        <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:orientation="horizontal"
           android:gravity="center_vertical"
           android:layout_marginBottom="6dp">
          <TextView
             android:id="@+id/breakdownLabel"
             style="@style/DialogSectionLabel"/>
          <Space
             android:layout_width="0dp"
             android:layout_height="wrap_content"
             android:layout_weight="1"/>
          <TextView
             android:id="@+id/movesSwitchLabel"
             android:layout_marginRight="6dp"
             android:text="@string/breakdown_moves"
             style="@style/DialogSectionLabel"/>
          <androidx.appcompat.widget.SwitchCompat
             android:id="@+id/swMoves"
             android:layout_width="wrap_content"
             android:layout_height="wrap_content"
             android:contentDescription="@string/breakdown_moves"/>
        </LinearLayout>

        <androidx.cardview.widget.CardView
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           style="@style/TableCardView">
          <LinearLayout
             android:orientation="vertical"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:padding="10dp">
            <com.cube.nanotimer.util.view.SolveStepBarView
               android:id="@+id/breakdownBar"
               android:layout_width="match_parent"
               android:layout_height="20dp"
               android:layout_marginBottom="6dp"/>
            <!-- What the bar adds up to, under the bar it describes. -->
            <TextView
               android:id="@+id/breakdownTotals"
               android:layout_gravity="center_horizontal"
               android:layout_marginBottom="8dp"
               android:visibility="gone"
               style="@style/BreakdownMeta"/>
            <TableLayout
               android:id="@+id/breakdownTable"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:stretchColumns="0"/>
          </LinearLayout>
        </androidx.cardview.widget.CardView>

      </LinearLayout>

      <!-- Averages -->
      <LinearLayout
         android:id="@+id/averagesTable"
         android:orientation="vertical"
         android:layout_width="match_parent"
         android:layout_height="wrap_content"
         android:layout_marginTop="14dp">

        <TextView
           android:text="@string/averages"
           android:layout_marginBottom="6dp"
           style="@style/DialogSectionLabel"/>

        <androidx.cardview.widget.CardView
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           style="@style/TableCardView">
          <TableLayout
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:padding="4dp"
             style="@style/EqualSizeColumnsTable">
            <TableRow>
              <TextView style="@style/AverageTableHeaderField" android:background="@color/transparent" android:text="5"/>
              <TextView style="@style/AverageTableHeaderField" android:background="@color/transparent" android:text="12"/>
              <TextView style="@style/AverageTableHeaderField" android:background="@color/transparent" android:text="50"/>
              <TextView style="@style/AverageTableHeaderField" android:background="@color/transparent" android:text="100"/>
            </TableRow>
            <TableRow>
              <TextView android:id="@+id/tvAvgOfFive" style="@style/TableCell" android:fontFeatureSettings="tnum"/>
              <TextView android:id="@+id/tvAvgOfTwelve" style="@style/TableCell" android:fontFeatureSettings="tnum"/>
              <TextView android:id="@+id/tvAvgOfFifty" style="@style/TableCell" android:fontFeatureSettings="tnum"/>
              <TextView android:id="@+id/tvAvgOfHundred" style="@style/TableCell" android:fontFeatureSettings="tnum"/>
            </TableRow>
          </TableLayout>
        </androidx.cardview.widget.CardView>

      </LinearLayout>

    </LinearLayout>

  </androidx.core.widget.NestedScrollView>

  <!-- Actions -->
  <LinearLayout
     android:layout_width="match_parent"
     android:layout_height="wrap_content"
     android:orientation="horizontal"
     android:gravity="center"
     android:layout_marginTop="14dp">
    <androidx.appcompat.widget.AppCompatButton
       android:id="@+id/buPlusTwo"
       android:text="@string/plus_two"
       android:layout_marginRight="6dp"
       android:layout_weight="1"
       style="@style/DialogActionButton"/>
    <androidx.appcompat.widget.AppCompatButton
       android:id="@+id/buDNF"
       android:text="@string/DNF"
       android:layout_marginLeft="6dp"
       android:layout_marginRight="6dp"
       android:layout_weight="1"
       style="@style/DialogActionButton"/>
    <androidx.appcompat.widget.AppCompatButton
       android:id="@+id/buDelete"
       android:text="@string/delete"
       android:layout_marginLeft="6dp"
       android:layout_weight="1"
       android:background="@drawable/dialog_action_button_danger"
       style="@style/DialogActionButton"/>
  </LinearLayout>

</LinearLayout>
